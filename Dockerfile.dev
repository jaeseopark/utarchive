# Development image with hot reloads
FROM node:24.17.0-alpine

WORKDIR /app

COPY package.json package-lock.json tsconfig.base.json ./
COPY backend/package.json backend/tsconfig.json ./backend/
COPY frontend/package.json frontend/tsconfig.json ./frontend/

RUN npm install

COPY . .

WORKDIR /app

# Install frontend dependencies with watch mode support
WORKDIR /app/frontend
RUN npm install

# Go back to app root
WORKDIR /app

# Force rebuild - $(date)
RUN echo "Building at $(date)"

EXPOSE 3000
EXPOSE 5173

# Install pg_isready tool
RUN apk add --no-cache postgresql-client

# Copy entrypoint script with cache bust
COPY docker/entrypoint.dev.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh && echo "Entrypoint updated"

ENTRYPOINT ["/app/entrypoint.sh"]
