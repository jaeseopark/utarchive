# Development image with hot reloads
FROM node:24.17.0-alpine

WORKDIR /app

COPY package.json package-lock.json tsconfig.base.json ./
COPY backend/package.json backend/tsconfig.json ./backend/
COPY frontend/package.json frontend/tsconfig.json ./frontend/

RUN npm install

COPY . .

WORKDIR /app

# Install frontend dependencies with watch mode support
WORKDIR /app/frontend
RUN npm install

# Go back to app root
WORKDIR /app

EXPOSE 3000
EXPOSE 5173

# Run both backend and frontend in dev mode
CMD ["npm", "run", "dev:docker"]
